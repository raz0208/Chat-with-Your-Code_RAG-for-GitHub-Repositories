# Store configuration variables to manages the API keys like OpenAI API key

import os
import getpass

# Get the OpenAI API key, GitHub Token, and Active Loop Token
os.environ["OPENAI_API_KEY"] = getpass.getpass("Enter your OpenAI API key: ")
os.environ["GITHUB_TOKEN"] = getpass.getpass("Enter your GitHub Token: ")
os.environ["ACTIVE_LOOP_TOKEN"] = getpass.getpass("Enter your Active Loop Token: ")

